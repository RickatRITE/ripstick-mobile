{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": false,
    "sourceMap": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@tiptap/*": ["node_modules/@tiptap/*"],
      "tiptap-markdown": ["node_modules/tiptap-markdown"]
    }
  },
  "include": ["src", "../shared"],
  "exclude": ["src/**/*.test.ts"]
}
